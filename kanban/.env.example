# 复制为服务器上的 /opt/kanban/.env 并填值(.env 不进 git)

# 会话签名密钥,生成:openssl rand -hex 64
SECRET_KEY=

# Plane 对外访问地址
WEB_URL=https://kanban.tokenwave.cloud
APP_DOMAIN=kanban.tokenwave.cloud
CORS_ALLOWED_ORIGINS=https://kanban.tokenwave.cloud
SITE_ADDRESS=:80

# Plane proxy(Caddy)纯 HTTP 跑在内网,但 Caddyfile 仍要求 acme_ca 有合法值
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory

# 管理员账号记录;Plane v1.3.1 不会自动消费这些变量,实际账号以数据库为准
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=管理员
ADMIN_USERNAME=admin
