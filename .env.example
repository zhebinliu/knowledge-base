# ===== 数据库 =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kb_system
POSTGRES_USER=kb_admin
POSTGRES_PASSWORD=change_me_strong_password

# ===== Qdrant =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=kb_chunks

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== MinIO =====
MINIO_ENDPOINT=minio:9000
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me_strong_password
MINIO_BUCKET=kb-documents

# ===== Embedding API =====
# 选项 1：硅基流动
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=your_siliconflow_key
EMBEDDING_MODEL=BAAI/bge-m3

# 选项 2：阿里 DashScope（取消注释以使用）
# EMBEDDING_PROVIDER=dashscope
# EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_API_KEY=your_dashscope_key
# EMBEDDING_MODEL=text-embedding-v3

# ===== Rerank API =====
RERANK_PROVIDER=siliconflow
RERANK_API_BASE=https://api.siliconflow.cn/v1
RERANK_API_KEY=your_siliconflow_key
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ===== 大模型 API Keys =====
# 文本类(chat)走 edgefn 代理 api.edgefn.net/v1,key 是 sk- 前缀的代理 key
ZHIPU_API_KEY=your_zhipu_key                  # GLM-5, GLM-4.7
MINIMAX_API_KEY=your_minimax_edgefn_proxy_key # MiniMax M2.5 / M2.7 chat,经 edgefn 代理
XIAOMI_API_KEY=your_xiaomi_key                # MiMo-V2-Pro, MiMo-V2-Omni
DASHSCOPE_API_KEY=your_dashscope_key          # Qwen3-Next, Qwen3-235B

# 图像类必须用 MiniMax 直连 key —— edgefn 代理只转发 chat,不转发 image_generation
# 从 https://platform.minimaxi.com 申请,用于会议解释图 / 文生图
# 见 LEARNING.md §12
MINIMAX_NATIVE_API_KEY=your_minimax_native_direct_key  # 直连 api.minimax.chat,for 文生图

# ===== 挑战配置 =====
CHALLENGE_AUTO_ACCEPT_THRESHOLD=0.9
CHALLENGE_REVIEW_THRESHOLD=0.7

# ===== 认证 / JWT(2026-05-12 加,必填) =====
# 生成方式:openssl rand -hex 32   或   python -c "import secrets;print(secrets.token_hex(32))"
# **必须改成随机字符串**,默认值"change-me-..."启动会 raise
JWT_SECRET_KEY=replace_me_with_32_byte_random_hex
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# 管理员初始账号(首次启动建库时用)
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=replace_me_strong_password

# ===== 运维(2026-05-12 加) =====
# 部署环境:production(默认,关 /docs)/ development(开 /docs)
KB_ENV=production

# Sentry 错误监控(可选):https://sentry.io 注册新项目拿 DSN
SENTRY_DSN=

# 部署失败 / SSL 续期失败的飞书机器人 webhook(可选)
DEPLOY_WEBHOOK_URL=

# 备份目标 GCS bucket(可选,scripts/backup.sh 用)
# BACKUP_GCS_BUCKET=gs://kb-system-backup
# SSL_HEALTHCHECK_URL=https://hc-ping.com/<uuid>
