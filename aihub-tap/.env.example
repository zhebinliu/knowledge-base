# 复制为 .env 并填入真实值(.env 已在 .gitignore)
# /opt/aihub-tap/.env 是服务器真实文件

# AIHUB Admin API (查询用户余额 / 消耗的 X-Admin-Key)
# 生成: openssl rand -base64 32 | tr -d '/+=' | cut -c1-40
AIHUB_ADMIN_KEY=changeme-40-char-random

# 直连 new-api postgres 查 users/logs 表(只读用法)
# 密码跟 /opt/new-api/.env 里的 POSTGRES_PASSWORD 一致
NEW_API_POSTGRES_DSN=postgres://newapi:CHANGEME_PASSWORD@new-api-postgres:5432/newapi
